# Duka Controller configuration
# Copy this file to config.toml and fill in the values marked CHANGEME.
# config.toml is gitignored and should never be committed.

# Web UI credentials
username = "CHANGEME"
password = "CHANGEME"
# How long a login session remains valid (seconds). Default: 24 hours.
session_ttl_secs = 86400

# Network
broadcast_address = "192.168.1.255"
duka_port = 4000
device_password = "1111"

# Background task intervals (seconds)
discovery_interval_secs = 30
status_interval_secs = 3

# Persistence
settings_file = "settings.json"

# Humidity-based fan speed automation
[automation]
latitude = 0.0    # CHANGEME: your location
longitude = 0.0   # CHANGEME: your location
# How often to fetch outdoor temperature+humidity from the weather API (seconds)
outdoor_fetch_interval_secs = 3600
# Fallback assumed indoor temperature (°C) used to convert indoor RH% to absolute humidity.
# Can be overridden per device via the automation API (e.g. set lower for basement devices).
assumed_indoor_temp_c = 20.0
# Indoor-minus-outdoor absolute humidity delta (g/m³) thresholds for each speed level.
# At 20°C: 1.5 g/m³ ≈ 10% RH,  3.0 g/m³ ≈ 20% RH
speed1_abs_humidity_delta = 0.0
speed2_abs_humidity_delta = 1.5
speed3_abs_humidity_delta = 3.0
# How long to wait after a speed increase before allowing automation to decrease it (seconds)
speed_decrease_lockout_secs = 3600
